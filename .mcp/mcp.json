{
  "mcpServers": {
    "stripe": {
      "command": "npx",
      "args": ["-y", "@stripe/mcp", "--tools=all", "--api-key=${STRIPE_SECRET_KEY}"],
      "env": {
        "STRIPE_SECRET_KEY": "${STRIPE_SECRET_KEY}"
      }
    },
    "turso": {
      "command": "npx",
      "args": ["-y", "@turso/mcp"],
      "env": {
        "TURSO_DATABASE_URL": "${DATABASE_URL}",
        "TURSO_AUTH_TOKEN": "${DATABASE_AUTH_TOKEN}"
      }
    },
    "shadcn": {
      "command": "npx",
      "args": ["shadcn@latest", "mcp"]
    },
    "svelte": {
      "command": "npx",
      "args": ["-y", "sv", "mcp"]
    }
  }
}
